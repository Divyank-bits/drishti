# ─────────────────────────────────────────────
# Drishti — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Dhan Broker ───────────────────────────────
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── Anthropic / Claude ─────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram Bot ──────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to send commands
# e.g. 123456789,987654321
TELEGRAM_AUTHORIZED_USER_IDS=

# ── App Modes (optional — defaults in config.js) ──
# INTELLIGENCE_MODE=HYBRID     # AI | RULES | HYBRID
# EXECUTION_MODE=PAPER         # PAPER | LIVE

# ── Dashboard ─────────────────────────────────
# DASHBOARD_PORT=3000

# ── Node Environment ──────────────────────────
# NODE_ENV=development          # development | production
